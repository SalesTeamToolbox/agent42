{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "frood": {
      "type": "local",
      "command": [
        "c:\\Users\\rickw\\projects\\frood\\.venv\\Scripts\\python.exe",
        "c:\\Users\\rickw\\projects\\frood\\mcp_server.py"
      ],
      "environment": {
        "FROOD_WORKSPACE": "c:\\Users\\rickw\\projects\\frood",
        "REDIS_URL": "redis://localhost:6379/0",
        "QDRANT_URL": "http://localhost:6333",
        "ZEN_PROXY_ENABLED": "true",
        "ZEN_PROXY_PORT": "8765"
      },
      "enabled": true
    },
    "jcodemunch": {
      "type": "local",
      "command": ["python", "-m", "jcodemunch_mcp.server"],
      "enabled": true
    },
    "frood-remote": {
      "type": "local",
      "command": ["ssh", "prod-server", "cd", "/opt/frood", "&&", "python", "mcp_server.py"],
      "enabled": false
    }
  },
  "provider": {
    "zen": {
      "name": "OpenCode Zen",
      "api": "openai",
      "options": {
        "baseURL": "http://127.0.0.1:8765",
        "apiKey": "${ZEN_API_KEY}"
      }
    }
  },
  "server": {
    "port": 22329
  },
  "instructions": ["AGENTS.md", "CLAUDE.md"]
}
