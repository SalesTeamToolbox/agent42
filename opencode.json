{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "frood": {
      "type": "local",
      "command": [
        "c:\\Users\\rickw\\projects\\frood\\.venv\\Scripts\\python.exe",
        "c:\\Users\\rickw\\projects\\frood\\mcp_server.py"
      ],
      "environment": {
        "FROOD_WORKSPACE": "c:\\Users\\rickw\\projects\\frood",
        "REDIS_URL": "redis://localhost:6379/0",
        "QDRANT_URL": "http://localhost:6333"
      },
      "enabled": true
    },
    "jcodemunch": {
      "type": "local",
      "command": ["uvx", "jcodemunch-mcp"],
      "enabled": true
    },
    "frood-remote": {
      "type": "local",
      "command": ["ssh", "prod-server", "cd", "/opt/frood", "&&", "python", "mcp_server.py"],
      "enabled": false
    }
  },
  "provider": {
    "frood": {
      "name": "Frood LLM proxy (OpenAI-compatible)",
      "api": "openai",
      "options": {
        "baseURL": "http://127.0.0.1:8002/llm/v1",
        "apiKey": "frood-local"
      }
    }
  },
  "server": {
    "port": 22329
  },
  "instructions": ["AGENTS.md", "CLAUDE.md"]
}
