{
  "permissions": {
    "allow": [
      "mcp__plugin_playwright_playwright__browser_fill_form",
      "Bash(python3 -c \":*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/security-gate.py",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/context-loader.py",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/security-monitor.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python .claude/hooks/format-on-write.py",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/jcodemunch-token-tracker.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/jcodemunch-reindex.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session-handoff.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/test-validator.py",
            "timeout": 45
          },
          {
            "type": "command",
            "command": "python .claude/hooks/learning-engine.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/jcodemunch-reindex.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
