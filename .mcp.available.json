{
  "_comment": "Full MCP server catalog. Use /mcp-activate <name> to enable a server.",
  "mcpServers": {
    "frood": {
      "command": "c:\\Users\\rickw\\projects\\frood\\.venv\\Scripts\\python.exe",
      "args": ["c:\\Users\\rickw\\projects\\frood\\mcp_server.py"],
      "env": {
        "FROOD_WORKSPACE": "c:\\Users\\rickw\\projects\\frood",
        "REDIS_URL": "redis://localhost:6379/0",
        "QDRANT_URL": "http://localhost:6333"
      }
    },
    "frood-remote": {
      "command": "ssh",
      "args": ["frood-prod", "cd ~/frood && FROOD_WORKSPACE=~/frood .venv/bin/python mcp_server.py"],
      "env": {}
    },
    "jcodemunch": {
      "command": "uvx",
      "args": ["jcodemunch-mcp"],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {}
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-server-playwright"],
      "env": {}
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    }
  }
}
